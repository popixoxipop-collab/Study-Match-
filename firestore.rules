rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'displayName', 'email', 'photoURL', 'track', 'score', 'createdAt']) &&
             data.uid is string &&
             data.displayName is string &&
             data.email is string &&
             (data.get('photoURL', '') == null || data.get('photoURL', '') is string) &&
             (data.get('track', '') == null || data.get('track', '') in ['', 'DX', 'AI']) &&
             data.score is number &&
             data.createdAt is timestamp;
    }
    
    function isValidIdea(data) {
      return hasOnlyAllowedFields(['authorId', 'authorName', 'title', 'description', 'status', 'createdAt', 'images', 'pdfUrl', 'driveLink', 'likesCount', 'likedBy']) &&
             data.authorId is string &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 2000 &&
             data.status in ['open', 'matched'] &&
             (data.get('images', []) == null || data.get('images', []) is list) &&
             (data.get('pdfUrl', '') == null || data.get('pdfUrl', '') is string) &&
             (data.get('driveLink', '') == null || data.get('driveLink', '') is string) &&
             (data.get('likesCount', 0) is number) &&
             (data.get('likedBy', []) is list) &&
             data.createdAt is timestamp;
    }
    
    function isValidStudyGroup(data) {
      return hasOnlyAllowedFields(['ideaId', 'ideaTitle', 'members', 'createdAt']) &&
             data.ideaId is string &&
             data.ideaTitle is string && data.ideaTitle.size() > 0 && data.ideaTitle.size() < 200 &&
             data.members is list && data.members.size() > 0 && data.members.size() <= 5 &&
             data.createdAt is timestamp;
    }
    
    function isValidMessage(data) {
      return hasOnlyAllowedFields(['groupId', 'senderId', 'senderName', 'text', 'createdAt']) &&
             data.groupId is string &&
             data.senderId is string &&
             data.senderName is string && data.senderName.size() > 0 && data.senderName.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && uidNotModified() &&
                    (isOwner(userId) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score']));
    }

    match /ideas/{ideaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidIdea(request.resource.data) && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && isValidIdea(request.resource.data) && 
                    (resource.data.authorId == request.auth.uid || 
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) && request.resource.data.status == 'matched') ||
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'likedBy']));
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    match /studyGroups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidStudyGroup(request.resource.data) && request.auth.uid in request.resource.data.members;
      allow update: if isAuthenticated() && isValidStudyGroup(request.resource.data) && 
                    (request.auth.uid in resource.data.members || request.auth.uid in request.resource.data.members);
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.members;
    }

    match /studyGroups/{groupId}/messages/{messageId} {
      allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/studyGroups/$(groupId)).data.members;
      allow create: if isAuthenticated() && isValidMessage(request.resource.data) && 
                    request.resource.data.senderId == request.auth.uid &&
                    request.auth.uid in get(/databases/$(database)/documents/studyGroups/$(groupId)).data.members;
    }
  }
}
